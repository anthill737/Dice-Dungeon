# Copy this file to .env at the repository root and add your real API key there.
ELEVENLABS_API_KEY=your_api_key_here

# Optional overrides
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_MODEL_ID=eleven_text_to_sound_v2

# The generator tries to save Godot-friendly WAV files by requesting PCM first.
# If your ElevenLabs plan does not support PCM, the script will fall back to MP3 automatically.
ELEVENLABS_OUTPUT_FORMAT=pcm_44100
